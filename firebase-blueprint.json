{
  "entities": {
    "Client": {
      "title": "Client",
      "description": "Esthetics clinic client",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "phone": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "preferences": { "type": "object" },
        "label": { "type": "string" },
        "labelColor": { "type": "string" },
        "ownerId": { "type": "string" }
      },
      "required": ["name", "ownerId"]
    },
    "Appointment": {
      "title": "Appointment",
      "description": "Scheduled service",
      "type": "object",
      "properties": {
        "clientId": { "type": "string" },
        "procedureId": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["pendente", "confirmado", "realizado", "faltou", "atrasado"] },
        "price": { "type": "number" },
        "paidAmount": { "type": "number" },
        "isPaid": { "type": "boolean" },
        "sessionNumber": { "type": "number" },
        "paymentMethod": { "type": "string" },
        "ownerId": { "type": "string" }
      },
      "required": ["clientId", "procedureId", "date", "ownerId"]
    },
    "Procedure": {
      "title": "Procedure",
      "description": "Clinic service",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "price": { "type": "number" },
        "duration": { "type": "number" },
        "ownerId": { "type": "string" }
      },
      "required": ["name", "price", "ownerId"]
    },
    "FinancialEntry": {
      "title": "FinancialEntry",
      "description": "Income or expense",
      "type": "object",
      "properties": {
        "description": { "type": "string" },
        "amount": { "type": "number" },
        "date": { "type": "string", "format": "date-time" },
        "type": { "type": "string", "enum": ["receita", "despesa"] },
        "category": { "type": "string" },
        "appointmentId": { "type": "string" },
        "ownerId": { "type": "string" }
      },
      "required": ["description", "amount", "date", "type", "ownerId"]
    },
    "Lead": {
      "title": "Lead",
      "description": "Potential customer with CRM data for conversion and lookalike audiences",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string" },
        "phone": { "type": "string" },
        "platform": { "type": "string" },
        "status": { "type": "string", "enum": ["novo", "follow-up-1", "convertido", "perdido"] },
        "lastMessage": { "type": "string" },
        "notes": { "type": "string" },
        "ownerId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "ownerId", "status"]
    },
    "Budget": {
      "title": "Budget",
      "description": "Service quote",
      "type": "object",
      "properties": {
        "clientId": { "type": "string" },
        "items": { "type": "array" },
        "total": { "type": "number" },
        "date": { "type": "string", "format": "date-time" },
        "status": { "type": "string" },
        "validUntil": { "type": "string", "format": "date-time" },
        "ownerId": { "type": "string" }
      },
      "required": ["clientId", "items", "total", "ownerId"]
    },
    "FollowUp": {
      "title": "FollowUp",
      "description": "Customer follow-up task",
      "type": "object",
      "properties": {
        "clientId": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "notes": { "type": "string" },
        "status": { "type": "string" },
        "ownerId": { "type": "string" }
      },
      "required": ["clientId", "date", "ownerId"]
    },
    "MessageTemplate": {
      "title": "MessageTemplate",
      "description": "WhatsApp message template",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "content": { "type": "string" },
        "category": { "type": "string", "enum": ["agendamento", "lembrete", "outros"] },
        "ownerId": { "type": "string" }
      },
      "required": ["name", "content", "ownerId"]
    },
    "UserProfile": {
      "title": "UserProfile",
      "description": "Professional's profile and business settings",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "businessName": { "type": "string" },
        "specialty": { "type": "string" },
        "phone": { "type": "string" },
        "address": { "type": "string" },
        "instagram": { "type": "string" },
        "workingHours": { "type": "object" },
        "workingDays": { "type": "array" },
        "budgetValidityDays": { "type": "number" },
        "clientLabel": { "type": "string" },
        "ownerId": { "type": "string" }
      },
      "required": ["name", "businessName", "ownerId"]
    },
    "AuthorizedEmail": {
      "title": "AuthorizedEmail",
      "description": "Emails authorized by purchase (Kiwify)",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "name": { "type": "string" },
        "status": { "type": "string" },
        "source": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["email"]
    },
    "AccessRequest": {
      "title": "AccessRequest",
      "description": "Requests for access after purchase",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "name": { "type": "string" },
        "whatsapp": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["email", "name", "status", "createdAt"]
    }
  },
  "firestore": {
    "/clients/{clientId}": { "schema": "Client", "description": "Clinic clients" },
    "/appointments/{appId}": { "schema": "Appointment", "description": "Service schedule" },
    "/procedures/{procId}": { "schema": "Procedure", "description": "Available services" },
    "/financialEntries/{entryId}": { "schema": "FinancialEntry", "description": "Financial records" },
    "/leads/{leadId}": { "schema": "Lead", "description": "Sales leads" },
    "/budgets/{budgetId}": { "schema": "Budget", "description": "Price quotes" },
    "/followUps/{fUpId}": { "schema": "FollowUp", "description": "Post-service follow-ups" },
    "/messageTemplates/{templateId}": { "schema": "MessageTemplate", "description": "WhatsApp message templates" },
    "/userProfiles/{userId}": { "schema": "UserProfile", "description": "User profile settings" },
    "/authorized_emails/{email}": { "schema": "AuthorizedEmail", "description": "Authorized emails list" },
    "/accessRequests/{requestId}": { "schema": "AccessRequest", "description": "Access requests after purchase" }
  }
}
