rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isSignedIn() { return request.auth != null; }
    
    // Mandate email verification for all writes in production
    function isVerified() { 
      return isSignedIn(); 
    }
    
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    
    function isOwner(userId) {
      return isVerified() && request.auth.uid == userId;
    }

    function isAdmin() {
      // Identity check
      return isSignedIn() && (
        request.auth.token.email.lower() == 'teus.rma@gmail.com' || 
        request.auth.token.email.lower() == 'brefer@gmail.com'
      );
    }

    // Generic Ownership Validator for collections using ownerId field
    function isDocOwner() {
      return isSignedIn() && (existing().ownerId == request.auth.uid || isAdmin());
    }

    // ===============================================================
    // Entity Validators
    // ===============================================================

    function isValidUserProfile(data) {
      return data.keys().hasAll(['name', 'businessName', 'ownerId']) &&
             data.name is string && data.name.size() <= 100 &&
             data.businessName is string && data.businessName.size() <= 100 &&
             data.ownerId == request.auth.uid &&
             (data.get('specialty', '') is string) &&
             (data.get('phone', '') is string) &&
             (data.get('clientLabel', 'Cliente') in ['Cliente', 'Paciente', 'Aluno', 'Membro']);
    }

    function isValidClient(data) {
      return data.keys().hasAll(['name', 'ownerId']) &&
             data.name is string && data.name.size() <= 100 &&
             data.ownerId == request.auth.uid;
    }

    function isValidAppointment(data) {
      return data.keys().hasAll(['clientId', 'procedureId', 'date', 'ownerId', 'status']) &&
             data.clientId is string &&
             data.procedureId is string &&
             data.status in ['pendente', 'confirmado', 'realizado', 'faltou', 'atrasado', 'desmarcado'] &&
             data.ownerId == request.auth.uid &&
             data.date is string && data.date.size() <= 50;
    }

    function isValidProcedure(data) {
      return data.keys().hasAll(['name', 'price', 'ownerId']) &&
             data.name is string && data.name.size() <= 100 &&
             data.price is number &&
             data.ownerId == request.auth.uid;
    }

    function isValidFinancial(data) {
      return data.keys().hasAll(['description', 'amount', 'date', 'type', 'ownerId']) &&
             data.description is string && data.description.size() <= 200 &&
             data.amount is number &&
             data.type in ['receita', 'despesa'] &&
             data.ownerId == request.auth.uid;
    }

    function isValidLead(data) {
      return data.keys().hasAll(['name', 'ownerId', 'status']) &&
             data.name is string && data.name.size() <= 100 &&
             data.status in ['novo', 'contato', 'proposta', 'convertido', 'perdido', 'follow-up-1'] &&
             data.ownerId == request.auth.uid &&
             (data.get('email', '') is string) &&
             (data.get('phone', '') is string) &&
             (data.get('platform', '') is string);
    }

    function isValidMessageTemplate(data) {
      return data.keys().hasAll(['name', 'content', 'ownerId']) &&
             data.name is string && data.name.size() <= 100 &&
             data.content is string && data.content.size() <= 2000 &&
             data.ownerId == request.auth.uid;
    }

    // ===============================================================
    // Match Blocks
    // ===============================================================

    // Authorized Emails (Kiwify Integration)
    match /authorized_emails/{email} {
      allow get, create: if isSignedIn() && request.auth.token.email.lower() == email.lower();
      allow list: if isAdmin();
    }

    // User Profiles
    match /userProfiles/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow create: if isOwner(userId) && isValidUserProfile(incoming());
      allow update: if (isOwner(userId) || isAdmin()) && 
                    isValidUserProfile(incoming()) &&
                    incoming().ownerId == existing().ownerId;
    }

    // Clients
    match /clients/{clientId} {
      allow get: if isDocOwner();
      allow list: if isSignedIn() && resource.data.ownerId == request.auth.uid;
      allow create: if isVerified() && isValidClient(incoming());
      allow update: if isVerified() && isDocOwner() && isValidClient(incoming());
      allow delete: if isVerified() && isDocOwner();
    }

    // Appointments
    match /appointments/{appId} {
      allow get: if isDocOwner();
      allow list: if isSignedIn() && resource.data.ownerId == request.auth.uid;
      allow create: if isVerified() && isValidAppointment(incoming());
      allow update: if isVerified() && isDocOwner() && isValidAppointment(incoming());
      allow delete: if isVerified() && isDocOwner();
    }

    // Procedures
    match /procedures/{procId} {
      allow get: if isDocOwner();
      allow list: if isSignedIn() && resource.data.ownerId == request.auth.uid;
      allow create: if isVerified() && isValidProcedure(incoming());
      allow update: if isVerified() && isDocOwner() && isValidProcedure(incoming());
      allow delete: if isVerified() && isDocOwner();
    }

    // Financial Entries
    match /financialEntries/{entryId} {
      allow get: if isDocOwner();
      allow list: if isSignedIn() && resource.data.ownerId == request.auth.uid;
      allow create: if isVerified() && isValidFinancial(incoming());
      allow update: if isVerified() && isDocOwner() && isValidFinancial(incoming());
      allow delete: if isVerified() && isDocOwner();
    }

    // Leads
    match /leads/{leadId} {
      allow get: if isDocOwner();
      allow list: if isSignedIn() && resource.data.ownerId == request.auth.uid;
      allow create: if isVerified() && isValidLead(incoming());
      allow update: if isVerified() && isDocOwner() && isValidLead(incoming()) && incoming().ownerId == existing().ownerId;
      allow delete: if isVerified() && isDocOwner();
    }

    // Budgets
    match /budgets/{budgetId} {
      allow get: if isDocOwner();
      allow list: if isSignedIn() && resource.data.ownerId == request.auth.uid;
      allow create: if isVerified() && incoming().ownerId == request.auth.uid;
      allow update: if isVerified() && isDocOwner() && incoming().ownerId == request.auth.uid;
      allow delete: if isVerified() && isDocOwner();
    }

    // FollowUps
    match /followUps/{fUpId} {
      allow get: if isDocOwner();
      allow list: if isSignedIn() && resource.data.ownerId == request.auth.uid;
      allow create: if isVerified() && incoming().ownerId == request.auth.uid;
      allow update: if isVerified() && isDocOwner() && incoming().ownerId == request.auth.uid;
      allow delete: if isVerified() && isDocOwner();
    }

    // Message Templates
    match /messageTemplates/{templateId} {
      allow get: if isDocOwner();
      allow list: if isSignedIn() && (resource.data.ownerId == request.auth.uid || isAdmin());
      allow create: if isVerified() && isValidMessageTemplate(incoming());
      allow update: if isVerified() && isDocOwner() && isValidMessageTemplate(incoming());
      allow delete: if isVerified() && isDocOwner();
    }

    // User Events (behavioral logs, tracking metrics)
    match /userEvents/{eventId} {
      allow create: if isSignedIn();
      allow get, list, update, delete: if isAdmin();
    }

    // Access Requests (from Thank You page)
    match /accessRequests/{requestId} {
      allow create: if true; 
      allow get, list, update, delete: if isAdmin();
    }
  }
}
